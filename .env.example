PORT=3000
DEV_PORT=5173

# Local development login. Do not use these defaults in a shared environment.
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# OpenClaw Gateway. Keep real tokens in your local .env only.
OPENCLAW_WS_URL=ws://localhost:18789
OPENCLAW_AUTH_TOKEN=

# Hermes Agent OpenAI-compatible API. Keep real API keys in your local .env only.
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=
